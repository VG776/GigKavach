# .env.example — GigKavach Configuration Template
# 
# Setup Instructions:
# 1. Copy this file: cp .env.example .env
# 2. Fill in actual values (never commit .env to git)
# 3. For Render: Set these as Environment Variables in the Render dashboard
# 4. For local dev: Fill .env and load with: source .env
#
# ⚠️  IMPORTANT: Never commit .env to git (already in .gitignore)

# ═══════════════════════════════════════════════════════════════════════════════
# Application Configuration
# ═══════════════════════════════════════════════════════════════════════════════
APP_ENV=development                  # development | production
APP_SECRET_KEY=your-secret-key-here  # Change in production!

# ═══════════════════════════════════════════════════════════════════════════════
# Frontend URLs (for CORS)
# ═══════════════════════════════════════════════════════════════════════════════
FRONTEND_LOCAL_URL=http://localhost:5173
FRONTEND_PRODUCTION_URL=https://gigkavach-frontend.vercel.app  # Update with your Vercel URL

# ═══════════════════════════════════════════════════════════════════════════════
# Database (Supabase)
# ═══════════════════════════════════════════════════════════════════════════════
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Redis (optional: use Render managed Redis or local)
REDIS_URL=redis://localhost:6379/0
# For Render: REDIS_URL=redis://:password@your-redis-host:port

# ═══════════════════════════════════════════════════════════════════════════════
# Messaging (Twilio)
# ═══════════════════════════════════════════════════════════════════════════════
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token-here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
TWILIO_SMS_NUMBER=+1234567890

# ═══════════════════════════════════════════════════════════════════════════════
# Payments (Razorpay)
# ═══════════════════════════════════════════════════════════════════════════════
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=key_secret_here
# Use test keys during development
# For production, switch to live keys after compliance review

# ═══════════════════════════════════════════════════════════════════════════════
# Weather APIs (DCI Engine)
# ═══════════════════════════════════════════════════════════════════════════════
TOMORROW_IO_API_KEY=your-tomorrow-io-key-here
# Fallback APIs (free tier)
OPENAQ_API_KEY=your-openaq-key-here
AQICN_API_TOKEN=your-aqicn-token-here

# ═══════════════════════════════════════════════════════════════════════════════
# DCI Engine Configuration
# ═══════════════════════════════════════════════════════════════════════════════
DCI_POLL_INTERVAL_SECONDS=300           # Poll every 5 minutes
DCI_TRIGGER_THRESHOLD=65                # DCI >= 65 triggers payout evaluation
DCI_CATASTROPHIC_THRESHOLD=85           # DCI >= 85 is catastrophic
DCI_CACHE_TTL_SECONDS=1800              # Cache for 30 minutes

# ═══════════════════════════════════════════════════════════════════════════════
# Fraud Detection Configuration
# ═══════════════════════════════════════════════════════════════════════════════
FRAUD_SOFT_FLAG_SIGNALS=3               # 2-3 signals = Tier 1 (soft flag)
FRAUD_HARD_BLOCK_SIGNALS=5              # 5+ signals = Tier 2 (hard block)
FRAUD_CONTAMINATION_RATE=0.05           # Isolation Forest contamination (5%)

# ═══════════════════════════════════════════════════════════════════════════════
# Payout Configuration
# ═══════════════════════════════════════════════════════════════════════════════
COVERAGE_DELAY_HOURS=24                 # New workers wait 24hrs before coverage
MAX_UPI_RETRY_ATTEMPTS=3                # Retry failed UPI transfers 3 times
UPI_RETRY_INTERVAL_MINUTES=40           # Retry interval: 40 minutes
ESCROW_WINDOW_HOURS=48                  # 48-hour window for worker correction

# ═══════════════════════════════════════════════════════════════════════════════
# Premium Tiers (Fixed Weekly Pricing)
# ═══════════════════════════════════════════════════════════════════════════════
SHIELD_BASIC_PREMIUM=69                 # ₹69/week
SHIELD_PLUS_PREMIUM=89                  # ₹89/week
SHIELD_PRO_PREMIUM=99                   # ₹99/week

SHIELD_BASIC_COVERAGE_PCT=0.40          # 40% coverage
SHIELD_PLUS_COVERAGE_PCT=0.50           # 50% coverage
SHIELD_PRO_COVERAGE_PCT=0.70            # 70% coverage

# ═══════════════════════════════════════════════════════════════════════════════
# Logging
# ═══════════════════════════════════════════════════════════════════════════════
LOG_LEVEL=INFO                          # DEBUG | INFO | WARNING | ERROR
LOG_FILE=logs/app.log

# ═══════════════════════════════════════════════════════════════════════════════
# Optional: Geocoding (for pin code mapping)
# ═══════════════════════════════════════════════════════════════════════════════
MAPPLS_API_KEY=your-mappls-key-here     # For reverse geocoding if needed

# ═══════════════════════════════════════════════════════════════════════════════
# Deployment Instructions
# ═══════════════════════════════════════════════════════════════════════════════
#
# FOR RENDER DEPLOYMENT:
# 1. Go to https://dashboard.render.com
# 2. Create new Web Service
# 3. Connect GitHub repository
# 4. Set "Start Command": uvicorn main:app --host 0.0.0.0 --port $PORT
# 5. Add Environment Variables = copy values from this file
# 6. Deploy!
#
# FOR VERCEL DEPLOYMENT (Frontend):
# 1. Go to https://vercel.com/dashboard
# 2. Import GitHub repository (frontend folder)
# 3. Set Environment Variables:
#    - VITE_API_BASE_URL=https://your-render-backend.onrender.com
#    - VITE_WS_BASE_URL=wss://your-render-backend.onrender.com
# 4. Deploy!
#
# ═══════════════════════════════════════════════════════════════════════════════
