{
  "version": 2,
  "env": {
    "VITE_API_BASE_URL": {
      "default": "https://your-render-backend.onrender.com"
    },
    "VITE_WS_BASE_URL": {
      "default": "wss://your-render-backend.onrender.com"
    }
  },
  "builds": [
    {
      "src": "frontend",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "status": 404
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": [
    "VITE_API_BASE_URL",
    "VITE_WS_BASE_URL"
  ]
}
