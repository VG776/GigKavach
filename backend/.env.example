# .env.example — GigKavach Configuration Template
# 
# Setup Instructions:
# 1. Copy this file: cp .env.example .env
# 2. Fill in actual values (never commit .env to git)
# 3. For Render: Set these as Environment Variables in the Render dashboard
# 4. For local dev: Fill .env and load with: source .env
#
# ⚠️  IMPORTANT: Never commit .env to git (already in .gitignore)

# ═══════════════════════════════════════════════════════════════════════════════
# Application Configuration
# ═══════════════════════════════════════════════════════════════════════════════
APP_ENV=development                  # development | production
APP_SECRET_KEY=your-secret-key-here  # Change in production!

# ═══════════════════════════════════════════════════════════════════════════════
# Frontend URLs (for CORS) — Development + Production
# ═══════════════════════════════════════════════════════════════════════════════
FRONTEND_LOCAL_URL=http://localhost:3000
# PRODUCTION: Set in Render dashboard
# FRONTEND_PRODUCTION_URL=https://your-vercel-app.vercel.app
WORKER_PWA_LOCAL_URL=http://localhost:4173
# PRODUCTION: Set worker PWA domain in Render dashboard
# WORKER_PWA_URL=https://your-worker-pwa.vercel.app

# ═══════════════════════════════════════════════════════════════════════════════
# Database (Supabase) — Get from supabase.com dashboard
# ═══════════════════════════════════════════════════════════════════════════════
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ═══════════════════════════════════════════════════════════════════════════════
# Redis Cache (Local: localhost, Production: Render Managed)
# ═══════════════════════════════════════════════════════════════════════════════
REDIS_URL=redis://localhost:6379/0
# PRODUCTION: Set Render managed Redis URL in Render dashboard

# ═══════════════════════════════════════════════════════════════════════════════
# Weather APIs (DCI Engine) — For Disruption Composite Index calculations
# ═══════════════════════════════════════════════════════════════════════════════
TOMORROW_IO_API_KEY=your-tomorrow-io-key-here
OPENAQ_API_KEY=your-openaq-key-here
AQICN_API_TOKEN=your-aqicn-token-here

# ═══════════════════════════════════════════════════════════════════════════════
# DCI Engine Configuration
# ═══════════════════════════════════════════════════════════════════════════════
DCI_POLL_INTERVAL_SECONDS=300           # Poll every 5 minutes
DCI_TRIGGER_THRESHOLD=65                # DCI >= 65 triggers payout evaluation
DCI_CATASTROPHIC_THRESHOLD=85           # DCI >= 85 is catastrophic
DCI_CACHE_TTL_SECONDS=1800              # Cache for 30 minutes

# ═══════════════════════════════════════════════════════════════════════════════
# Fraud Detection Configuration
# ═══════════════════════════════════════════════════════════════════════════════
FRAUD_SOFT_FLAG_SIGNALS=3               # 2-3 signals = Tier 1 (soft flag)
FRAUD_HARD_BLOCK_SIGNALS=5              # 5+ signals = Tier 2 (hard block)
FRAUD_CONTAMINATION_RATE=0.05           # Isolation Forest contamination (5%)

# ═══════════════════════════════════════════════════════════════════════════════
# Payout Configuration
# ═══════════════════════════════════════════════════════════════════════════════
COVERAGE_DELAY_HOURS=24                 # New workers wait 24hrs before coverage
MAX_UPI_RETRY_ATTEMPTS=3                # Retry failed UPI transfers 3 times
UPI_RETRY_INTERVAL_MINUTES=40           # Retry interval: 40 minutes
ESCROW_WINDOW_HOURS=48                  # 48-hour window for worker correction

# ═══════════════════════════════════════════════════════════════════════════════
# Premium Tiers (Fixed Weekly Pricing)
# ═══════════════════════════════════════════════════════════════════════════════
SHIELD_BASIC_PREMIUM=69                 # ₹69/week
SHIELD_PLUS_PREMIUM=89                  # ₹89/week
SHIELD_PRO_PREMIUM=99                   # ₹99/week

SHIELD_BASIC_COVERAGE_PCT=0.40          # 40% coverage
SHIELD_PLUS_COVERAGE_PCT=0.50           # 50% coverage
SHIELD_PRO_COVERAGE_PCT=0.70            # 70% coverage

# ═══════════════════════════════════════════════════════════════════════════════
# Logging Configuration
# ═══════════════════════════════════════════════════════════════════════════════
LOG_LEVEL=INFO                          # DEBUG | INFO | WARNING | ERROR
LOG_FILE=logs/app.log

# ═══════════════════════════════════════════════════════════════════════════════
# Optional: Geocoding APIs (for pin code mapping)
# ═══════════════════════════════════════════════════════════════════════════════
MAPPLS_API_KEY=your-mappls-key-here

# ═══════════════════════════════════════════════════════════════════════════════
# WhatsApp Bot Configuration (Web-based)
# ═══════════════════════════════════════════════════════════════════════════════
BOT_API_URL=http://localhost:3001
WHATSAPP_PHONE_NUMBER=your-phone-number-here
