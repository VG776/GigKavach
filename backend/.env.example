# .env.example — GigKavach Configuration Template
# 
# Setup Instructions:
# 1. Copy this file: cp .env.example .env
# 2. Fill in actual values (never commit .env to git)
# 3. For Render: Set these as Environment Variables in the Render dashboard
# 4. For local dev: Fill .env and load with: source .env
#
# ⚠️  IMPORTANT: Never commit .env to git (already in .gitignore)

# ═══════════════════════════════════════════════════════════════════════════════
# Application Configuration
# ═══════════════════════════════════════════════════════════════════════════════
APP_ENV=development                  # development | production
APP_SECRET_KEY=your-secret-key-here  # Change in production!

# ═══════════════════════════════════════════════════════════════════════════════
# Frontend URLs (for CORS) — Supports both localhost and server IP
# ═══════════════════════════════════════════════════════════════════════════════
# LOCALHOST: http://localhost:3000 (npm run dev)
# SERVER: http://13.51.165.52:3000  (deployed)
FRONTEND_LOCAL_URL=http://localhost:3000
FRONTEND_SERVER_URL=http://13.51.165.52:3000
FRONTEND_URL=http://13.51.165.52:3000
FRONTEND_PRODUCTION_URL=https://gigkavach-delta.vercel.app

