# ═══════════════════════════════════════════════════════════════════════════════
# Weather APIs (DCI Engine)
# ═══════════════════════════════════════════════════════════════════════════════
TOMORROW_IO_API_KEY=MD36I2GcYp3gBoUlnKvdQeHkBJQvTF19
# Fallback APIs (free tier)
OPENAQ_API_KEY=885d52c7b9d35c87345de923622c6481fb5be3ec1b2a57952956cd5c386c2f0b
