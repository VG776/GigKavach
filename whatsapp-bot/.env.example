# ═════════════════════════════════════════════════════════════════════════════
# GigKavach WhatsApp Bot Environment Configuration
# ═════════════════════════════════════════════════════════════════════════════
# Setup: Copy this file to .env and fill in your values

# ──── Backend Connection ──────────────────────────────────────────────────────
# Bot communicates with backend API for worker registration and DCI updates
# LOCAL: http://localhost:8000 (npm run dev)
# SERVER: http://13.51.165.52:8000 (deployed)
BACKEND_URL=http://localhost:8000

# ──── Bot Server Configuration ────────────────────────────────────────────────
# Bot Express server runs on port 3001
BOT_PORT=3001
DEBUG=false

# ──── WhatsApp Session Storage ────────────────────────────────────────────────
# Automatically handled by whatsapp-web.js via LocalAuth
# Sessions stored in: ./sessions/

# ──── WhatsApp Business Account ───────────────────────────────────────────────
WHATSAPP_PHONE_NUMBER=8792525542

# ──── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ──── Webhook (Optional) ───────────────────────────────────────────────────────
# If you need to notify backend of bot events
# WEBHOOK_URL=https://your-backend.com/whatsapp-webhook

# ═════════════════════════════════════════════════════════════════════════════
# PORT MAPPING REFERENCE:
# ═════════════════════════════════════════════════════════════════════════════
# Frontend:     localhost:3000   OR   13.51.165.52:3000
# Backend:      localhost:8000   OR   13.51.165.52:8000
# WhatsApp Bot: localhost:3001   OR   13.51.165.52:3001
# ═════════════════════════════════════════════════════════════════════════════

