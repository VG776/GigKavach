# ═════════════════════════════════════════════════════════════════════════════
# GigKavach WhatsApp Bot Environment Configuration
# ═════════════════════════════════════════════════════════════════════════════
# Setup: Copy this file to .env and fill in your values
# IMPORTANT: Never commit .env to git (already in .gitignore)

# ─ Backend API Connection ──────────────────────────────────────────────────────
# Bot communicates with backend for worker registration and DCI updates
# LOCAL: http://localhost:8000
# PRODUCTION: https://gigkavach-backend.onrender.com (when available)
BACKEND_URL=http://localhost:8000

# ─ Bot Server Configuration ────────────────────────────────────────────────────
BOT_PORT=3001
DEBUG=false

# ─ WhatsApp Session Storage ────────────────────────────────────────────────────
# Automatically handled by whatsapp-web.js via LocalAuth
SESSION_DIR=./sessions

# ─ WhatsApp Business Account ───────────────────────────────────────────────────
WHATSAPP_PHONE_NUMBER=your-phone-number-here

# ─ Logging Configuration ──────────────────────────────────────────────────────
LOG_LEVEL=info

# ═════════════════════════════════════════════════════════════════════════════
# DEPLOYMENT REFERENCE
# ═════════════════════════════════════════════════════════════════════════════
# When deploying to production, update BACKEND_URL to point to Render backend:
# BACKEND_URL=https://gigkavach-backend.onrender.com

