# ──────────────────────────────────────────────────────────────
# GigKavach WhatsApp Bot Environment Configuration
# ──────────────────────────────────────────────────────────────

# Backend API URL (where worker registration and DCI endpoints are)
BACKEND_URL=http://localhost:8000

# Bot API Port (Express server)
BOT_PORT=3001

# WhatsApp Session Storage
# (Automatically handled by whatsapp-web.js via LocalAuth)
# Sessions stored in: ./data/sessions/

# Logging
LOG_LEVEL=info

# Optional: Webhook callback URL (if you need to notify backend of bot events)
# WEBHOOK_URL=https://your-backend.com/whatsapp-webhook
