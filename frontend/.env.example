# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─ Deployment Targets (update these first) ───────────────────────────────────
# LOCAL
VITE_API_URL=http://localhost:8000
VITE_API_BASE_URL=http://localhost:8000
VITE_BACKEND_PROXY_TARGET=http://localhost:8000
VITE_WS_BASE_URL=ws://localhost:8000

# PRODUCTION
# VITE_API_BASE_URL=https://your-render-backend.onrender.com
# VITE_FRONTEND_URL=https://your-vercel-app.vercel.app
# Or leave VITE_API_BASE_URL unset and use the Vercel /api rewrite to proxy to Render


# ─ Feature Flags ───────────────────────────────────────────────────────────────
VITE_ENABLE_MOCK_DATA=false
VITE_DEBUG_MODE=false

# ─ Share Token Configuration ──────────────────────────────────────────────────
# Share tokens allow workers to share their profiles via WhatsApp links
# Frontend generates tokens via backend API: POST /api/share-tokens/generate
# Public profiles accessed via: /share/worker/:token

