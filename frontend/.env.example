# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─ Backend API Configuration (Local Development + Production) ────────────────
# LOCAL: When running backend locally (docker-compose or npm run dev)
VITE_API_URL=http://localhost:8000
VITE_API_BASE_URL=http://localhost:8000
VITE_BACKEND_PROXY_TARGET=http://localhost:8000
VITE_WS_BASE_URL=ws://localhost:8000

# PRODUCTION: Will be set via Vercel environment variables
# TODO: Backend URL will be https://your-render-backend.onrender.com

# ─ Feature Flags ───────────────────────────────────────────────────────────────
VITE_ENABLE_MOCK_DATA=false
VITE_DEBUG_MODE=false

# ─ Share Token Configuration ──────────────────────────────────────────────────
# Share tokens allow workers to share their profiles via WhatsApp links
# Frontend generates tokens via backend API: POST /api/share-tokens/generate
# Public profiles accessed via: /share/worker/:token

